@model List<MinesweeperMilestone.Models.SaveGame>

<div class="container text-center mt-5">
    <h1>Your Saved Games</h1>
    <p>Choose a game to resume or delete.</p>

    <!-- Display message if there are no saved games -->
    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">You have no saved games right now.</div>
        <a asp-action="Index" class="btn btn-primary">Start a New Game</a>
    }
    <!-- Display table of saved games -->
    else
    {
        <table class="table table-striped table-bordered mt-4">
            <thead class="thead-dark">
                <tr>
                    <th>Save ID</th>
                    <th>Date & Time Saved</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    <tr>
                        <td class="align-middle">@game.Id</td>
                        <td class="align-middle">@game.Date.ToString("g")</td>
                        <td>
                            <form asp-action="ProcessLoadGame" method="post" style="display:inline-block;">
                                <input type="hidden" name="gameId" value="@game.Id" />
                                <button type="submit" class="btn btn-success">Load Game</button>
                            </form>

                            <form asp-action="ProcessDeleteGame" method="post" style="display:inline-block;">
                                <input type="hidden" name="gameId" value="@game.Id" />
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this save?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>