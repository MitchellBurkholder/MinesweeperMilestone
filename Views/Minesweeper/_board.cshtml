@model MinesweeperMilestone.Models.Board
@{
    var gameService = new MinesweeperMilestone.Services.GameService(Model);
    
    var currentState = gameService.CheckGameState();
    bool isGameOver = currentState != MinesweeperMilestone.Models.Board.GameState.InProgress;
}

@if (currentState == MinesweeperMilestone.Models.Board.GameState.Won)
{
    <div class="alert alert-success">
        <h2 class="text-success">You Win!</h2>
        <h3>Final Score: @gameService.DetermineFinalScore()</h3>
        <a asp-action="StartGame" asp-controller="User" class="btn btn-success">New Game</a>
    </div>
}
else if (currentState == MinesweeperMilestone.Models.Board.GameState.Lost)
{
    <div class="alert alert-danger">
        <h2 class="text-danger">Game Over! You hit a mine.</h2>
        <h3>Final Score: @Model.Score</h3>
        <a asp-action="StartGame" asp-controller="User" class="btn btn-primary">Try Again</a>
    </div>
}
else
{
    <h3>Score: @Model.Score</h3>
}

<div style="display: inline-block; margin-top: 20px; border: 5px solid #7b7b7b;">
    @for (int r = 0; r < Model.size; r++)
    {
        <div style="display: flex;">
            @for (int c = 0; c < Model.size; c++)
            {
                var cell = Model.cells[r, c];

                @(await Html.PartialAsync("_Cells", cell, new ViewDataDictionary(ViewData) {
                    { "isGameOver", isGameOver },
                    { "r", r},
                    { "c", c}
                }))
            }
        </div>
    }
</div>