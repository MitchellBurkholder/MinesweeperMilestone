@model MinesweeperMilestone.Models.Board

@{
    ViewData["Title"] = "Minesweeper Board";
}

<div class="text-center">
    <h1 class="display-4">Minesweeper</h1>

    @if (Model.CheckGameState() == MinesweeperMilestone.Models.Board.GameState.Won)
    {
        <h2 class="text-success">You Win!</h2>
        <h3>Final Score: @Model.DetermineFinalScore()</h3>
    }
    else if (Model.CheckGameState() == MinesweeperMilestone.Models.Board.GameState.Lost)
    {
        <h2 class="text-danger">Game Over! You hit a mine.</h2>
        <h3>Final Score: @Model.Score</h3>
    }
    else
    {
        <h3>Score: @Model.Score</h3>
    }

    <div style="display: inline-block; margin-top: 20px;">
        @for (int r = 0; r < Model.size; r++)
        {
            <div style="display: flex;">
                @for (int c = 0; c < Model.size; c++)
                {
                    var cell = Model.cells[r, c];
                    string imagePath = "";
                    
                    // Determine which image to show based on the cell's state
                    if (cell.isVisited)
                    {
                        // Bomb
                        if (cell.isBomb)
                        {
                            imagePath = "~/img/Minesweeper_Bomb.png";
                        }
                        // Numbered cells
                        else if (cell.numBombNeighbors > 0)
                        {
                            // Dynamically grab the image based on the number
                            imagePath = $"~/img/Minesweeper_{cell.numBombNeighbors}.png";
                        }
                        // The flat, revealed blank square
                        else
                        {
                            imagePath = "~/img/Minesweeper_Empty.png";
                        }
                    }
                    else
                    {
                        // Flag
                        if (cell.isFlagged)
                        {
                            imagePath = "~/img/Minesweeper_flag.png";
                        }
                        // Raised, clickable cell
                        else
                        {
                            imagePath = "~/img/Minesweeper_unopened_square.png";
                        }
                    }
                    
                    // Render the cell
                    var cellStyle = "width: 40px; height: 40px; display: block; border: none; padding: 0;";

                    if (cell.isVisited)
                    {
                        // Visited Cell (Not clickable)
                        <div style="@cellStyle">
                            <img src="@Url.Content(imagePath)" alt="Cell" style="width: 100%; height: 100%; display: block;" />
                        </div>
                    }
                    else
                    {
                        // route the click to the "Visit" action and pass the coordinates
                        // Unvisited Cell (Clickable)
                        <a asp-action="Visit" asp-route-row="@r" asp-route-col="@c" style="@cellStyle">
                            <img src="@Url.Content(imagePath)" alt="Unvisited Cell" style="width: 100%; height: 100%; display: block;" />
                        </a>
                    }
                }
            </div>
        }
    </div>
</div>