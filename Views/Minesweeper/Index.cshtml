@model MinesweeperMilestone.Models.Board

@{
    ViewData["Title"] = "Minesweeper Board";
    // Check game state
    var currentState = Model.CheckGameState();
    bool isGameOver = currentState != MinesweeperMilestone.Models.Board.GameState.InProgress;
}

<div class="text-center">
    <h1 class="display-4">Minesweeper</h1>

    @if (currentState == MinesweeperMilestone.Models.Board.GameState.Won)
    {
        <div class="alert alert-success">
            <h2 class="text-success">You Win!</h2>
            <h3>Final Score: @Model.DetermineFinalScore()</h3>
            <a asp-action="StartGame" asp-controller="User" class="btn btn-success">New Game</a>
        </div>
    }
    else if (currentState == MinesweeperMilestone.Models.Board.GameState.Lost)
    {
        <div class="alert alert-danger">
            <h2 class="text-danger">Game Over! You hit a mine.</h2>
            <h3>Final Score: @Model.Score</h3>
            <a asp-action="StartGame" asp-controller="User"  class="btn btn-primary">Try Again</a>
        </div>
    }
    else
    {
        <h3>Score: @Model.Score</h3>
    }

    <div style="display: inline-block; margin-top: 20px; border: 5px solid #7b7b7b;">
        @for (int r = 0; r < Model.size; r++)
        {
            <div style="display: flex;">
                @for (int c = 0; c < Model.size; c++)
                {
                    var cell = Model.cells[r, c];

                    // The the ViewDataDictionary class is use to move specific data from this view to the partial one
                    @await Html.PartialAsync("_Cells", cell, new ViewDataDictionary(ViewData) {
                        { "isGameOver", isGameOver }, 
                        { "r", r}, 
                        { "c", c} });
                }
            </div> <!--Inner-Loop body-->
        }<!--Outer loop body-->
    </div><!--code for cell rednering-->
</div>


<!--The scripts below might be causing a problem. -->


@section Scripts {
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
            <script>

            // Right-Click Flag Logic
            function handleRightClick(event, row, col) {
                event.preventDefault(); // Stop the default browser context menu
                window.location.href = `/Minesweeper/Flag?row=${row}&col=${col}`;
            }

            // Left Click AJAX Logic
            $(document).ready(function(){
                $(document).on("click", ".game-button button", function(e){
                    e.preventDefault();
            
                    var row = $(this).data("row");
                    var col = $(this).data("col");
                    var wrapper = $(this).closest(".game-button");
                    var token = $('input[name="__RequestVerificationToken"]').val();
            
                    $(this).prop("disabled", true);
            
                    $.ajax({
                        type: "POST",
                        url: "/MineSweeper/PartialPageCellUpdate",
                        data: {row: row, col: col},
                        headers: token ? { "RequestVerificationToken": token } : {},

                        success: function(html){
                            wrapper.replaceWith(html);
                        },

                        error: function(xhr, status, error){
                        console.error("An error occurred: " + error);
                        }
                    });
                }); 
            });
    </script>
        }
}
